# DuxxDB docker-compose configuration.
#
# Copy this file to ".env" in the same directory:
#   cp .env.example .env
# Then edit the values below before running `docker compose up -d`.
#
# Lines starting with '#' are comments. Empty values inherit the
# defaults baked into docker-compose.yml.

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# Authentication token. Every client must send this via:
#   redis-cli -p 6379 -a <token>
#   AUTH <token>
# Generate a strong value:
#   openssl rand -hex 32
DUXX_TOKEN=replace-me-with-openssl-rand-hex-32

# -----------------------------------------------------------------------------
# OPTIONAL - networking
# -----------------------------------------------------------------------------

# Host port to expose RESP on (container always listens on 6379 internally).
DUXX_PORT=6379

# Host port for Prometheus /metrics + /health endpoint.
DUXX_METRICS_PORT=9100

# Host port for the bundled Prometheus scraper (only started with
# `docker compose --profile metrics up -d`).
PROMETHEUS_PORT=9090

# -----------------------------------------------------------------------------
# OPTIONAL - embedder
# -----------------------------------------------------------------------------

# Default is the deterministic toy embedder (32-d hash buckets).
# Switch to a real one for production:
#   DUXX_EMBEDDER=openai:text-embedding-3-small
#   DUXX_EMBEDDER=openai:text-embedding-3-large
#   DUXX_EMBEDDER=cohere:embed-english-v3.0
DUXX_EMBEDDER=hash:32

# Required if and only if DUXX_EMBEDDER points at OpenAI / Cohere.
# OPENAI_API_KEY=sk-...
# COHERE_API_KEY=...

# -----------------------------------------------------------------------------
# OPTIONAL - logging
# -----------------------------------------------------------------------------

# Verbosity. Use `info` for prod, `debug` for troubleshooting.
RUST_LOG=info
