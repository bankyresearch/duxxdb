# /etc/duxxdb/duxx.env
#
# Environment variables for duxx-server (read by systemd via the unit's
# EnvironmentFile= directive).
#
# After editing this file:
#   sudo systemctl restart duxxdb

# -----------------------------------------------------------------------------
# Authentication token (REQUIRED in production).
# Generate a strong value:   openssl rand -hex 32
# -----------------------------------------------------------------------------
DUXX_TOKEN=
# Optional role-based API key catalog:
#   principal:token:role[:tenant],principal2:token2:role[:tenant]
# Roles: read, write, admin. Tenant-scoped keys are limited to tenant-safe
# RESP commands and namespace memory/session keys as <tenant>:<key>.
# DUXX_AUTH_KEYS=reader:REPLACE_WITH_TOKEN:read,writer:REPLACE_WITH_TOKEN:write:tenant-a

# -----------------------------------------------------------------------------
# Security audit log. JSON lines; keep on durable storage and ship to your SIEM.
# -----------------------------------------------------------------------------
# DUXX_AUDIT_LOG=/var/log/duxxdb/audit.jsonl

# -----------------------------------------------------------------------------
# Storage backend.
#   memory:_                  in-memory only (lost on restart)
#   redb:/path/to/file.redb   durable rows; indices rebuilt on open
#   dir:/path/to/directory    fully persistent (rows + tantivy + HNSW)
# -----------------------------------------------------------------------------
DUXX_STORAGE=dir:/var/lib/duxxdb
DUXX_PHASE7_STORAGE=dir:/var/lib/duxxdb/phase7

# -----------------------------------------------------------------------------
# Embedder.
#   hash:32                            deterministic toy (default)
#   openai:text-embedding-3-small      requires OPENAI_API_KEY
#   openai:text-embedding-3-large      requires OPENAI_API_KEY
#   cohere:embed-english-v3.0          requires COHERE_API_KEY
# -----------------------------------------------------------------------------
DUXX_EMBEDDER=hash:32
# OPENAI_API_KEY=
# COHERE_API_KEY=

# -----------------------------------------------------------------------------
# Prometheus /metrics + /health endpoint.
# Comment out to disable.
# -----------------------------------------------------------------------------
DUXX_METRICS_ADDR=127.0.0.1:9100

# -----------------------------------------------------------------------------
# Optional native TLS / mTLS.
# Set cert + key together. Add DUXX_TLS_CLIENT_CA to require client certs.
# -----------------------------------------------------------------------------
# DUXX_TLS_CERT=/etc/duxxdb/tls/server.crt
# DUXX_TLS_KEY=/etc/duxxdb/tls/server.key
# DUXX_TLS_CLIENT_CA=/etc/duxxdb/tls/client-ca.crt

# -----------------------------------------------------------------------------
# RESP protocol resource limits. Defaults are conservative for public services;
# lower them for tightly-scoped internal workloads.
# -----------------------------------------------------------------------------
# DUXX_MAX_BULK_BYTES=16777216
# DUXX_MAX_ARRAY_ITEMS=4096
# DUXX_MAX_LINE_BYTES=65536
# DUXX_MAX_INPUT_BUFFER_BYTES=33554432
# DUXX_MAX_NESTING_DEPTH=64
# DUXX_MAX_CONNECTIONS=10000
# DUXX_MAX_COMMANDS_PER_SEC=1000

# -----------------------------------------------------------------------------
# Logging verbosity. Use `info` for production, `debug` for troubleshooting.
# -----------------------------------------------------------------------------
RUST_LOG=info
