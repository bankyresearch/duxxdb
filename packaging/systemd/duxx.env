# /etc/duxxdb/duxx.env
#
# Environment variables for duxx-server (read by systemd via the unit's
# EnvironmentFile= directive).
#
# After editing this file:
#   sudo systemctl restart duxxdb

# -----------------------------------------------------------------------------
# Authentication token (REQUIRED in production).
# Generate a strong value:   openssl rand -hex 32
# -----------------------------------------------------------------------------
DUXX_TOKEN=

# -----------------------------------------------------------------------------
# Storage backend.
#   memory:_                  in-memory only (lost on restart)
#   redb:/path/to/file.redb   durable rows; indices rebuilt on open
#   dir:/path/to/directory    fully persistent (rows + tantivy + HNSW)
# -----------------------------------------------------------------------------
DUXX_STORAGE=dir:/var/lib/duxxdb

# -----------------------------------------------------------------------------
# Embedder.
#   hash:32                            deterministic toy (default)
#   openai:text-embedding-3-small      requires OPENAI_API_KEY
#   openai:text-embedding-3-large      requires OPENAI_API_KEY
#   cohere:embed-english-v3.0          requires COHERE_API_KEY
# -----------------------------------------------------------------------------
DUXX_EMBEDDER=hash:32
# OPENAI_API_KEY=
# COHERE_API_KEY=

# -----------------------------------------------------------------------------
# Prometheus /metrics + /health endpoint.
# Comment out to disable.
# -----------------------------------------------------------------------------
DUXX_METRICS_ADDR=127.0.0.1:9100

# -----------------------------------------------------------------------------
# Logging verbosity. Use `info` for production, `debug` for troubleshooting.
# -----------------------------------------------------------------------------
RUST_LOG=info
